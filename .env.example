# ══════════════════════════════════════════════════════════════════
#  IRIS — Arquivo de configuração de ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA commite o arquivo .env no Git.
# ══════════════════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────────────────
# Gere uma chave segura com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=substitua_por_uma_chave_aleatoria_de_64_chars

# Ambiente: "development" (debug ativo) ou "production" (debug desativado, HTTPS obrigatório)
FLASK_ENV=development

# ── Mercado Pago (opcional — necessário para planos pagos) ─────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel
MERCADO_PAGO_ACCESS_TOKEN=seu_access_token_aqui

# ── IA / Agente (opcional — necessário para o Agente IRIS) ─────────
# Anthropic Claude: https://console.anthropic.com/
ANTHROPIC_API_KEY=sua_chave_aqui

# OpenRouter (alternativa gratuita): https://openrouter.ai/keys
OPENROUTER_API_KEY=sua_chave_aqui
